@{
    ViewBag.Title = "R1FormList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="app-content main-content">
    <div class="side-app">
        <div class="container-fluid main-container">

            <!--Page header-->
            <div class="page-header">
                <div class="page-leftheader">
                    <h4 class="page-title">Form List</h4>
                </div>

            </div>

            <!--End Page header-->
            <!--1-Admin && 5-HQ-->
            <div class="" id=contentAdmin>
                <div class="col-lg-12 col-md-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="mb-3 m-0">
                                <div class="row">
                                    <div class="col-3">
                                        <label class="mt-5 form-label">Region</label>
                                        <select id="region" class="form-control form-select select2">
                                            <option value="-0">Select Region</option>
                                        </select>
                                    </div>
                                    <div class="col-3">
                                        <label class="mt-5 form-label">KMUJ</label>
                                        <select id="kmuj" class="form-control form-select select2">
                                            <option value="-0">Select KMUJ</option>
                                        </select>
                                    </div>
                                    <div class="col-3">
                                        <label class="mt-5 form-label">Section</label>
                                        <select id="section" class="form-control form-select select2">
                                            <option value="-0">Select Section</option>
                                        </select>
                                    </div>
                                    <div class="col-2">
                                        <label class="mt-5 form-label">Work Date (From - To)</label>
                                        <div class="input-group">
                                            <div class="input-group-append">
                                                <span class="input-group-text"><i class=" mt-1 mb-1 fa fa-solid fa fa-calendar font-20"></i></span>
                                            </div>
                                            <input type="text" class="form-control" id="txtDate" placeholder="Select Work Date" required="required" autocomplete="off" />
                                        </div>
                                    </div>
                                    <div class="col-1">
                                        <label class="mt-5 form-label text-white">.</label>
                                        <button id="btnSearch" class="btn btn-primary">Search</button>
                                    </div>
                                    <div class="card-body">
                                        <div class="col-lg-12">
                                            <div class="table-responsive table-lg">
                                                <table id="tableAdmin" class="table table-striped table-bordered text-nowrap">
                                                    <thead>
                                                    </thead>
                                                    <tbody></tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="" id=contentNormal>
                <div class="col-lg-12 col-md-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="mb-3 m-0">
                                <div class="row justify-content-end">
                                    <div class="col-2">
                                        <label class="mt-5 form-label">Work Date (From - To)</label>
                                        <div class="input-group">
                                            <div class="input-group-append">
                                                <span class="input-group-text"><i class=" mt-1 mb-1 fa fa-solid fa fa-calendar font-20"></i></span>
                                            </div>
                                            <input type="text" class="form-control" id="txtDate3" placeholder="Select Work Date" required="required" autocomplete="off" />
                                        </div>
                                    </div>
                                    <div class="col-1">
                                        <label class="mt-5 form-label text-white">.</label>
                                        <button id="btnSearch3" class="btn btn-primary">Search</button>
                                    </div>
                                    <div class="card-body">
                                        <div class="col-lg-12">
                                            <div class="table-responsive table-lg">
                                                <table id="tableNormal" class="table table-striped table-bordered text-nowrap">
                                                    <thead>
                                                    </thead>
                                                    <tbody></tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="container-fluid" id="contentOthers">
                <div class="card border-0 shadow-sm ">
                    <div class="card-body p-4 text-center mt-5 mb-5">
                        <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-circle p-3 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-exclamation-triangle" viewBox="0 0 16 16">
                                <path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.15.15 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.2.2 0 0 1-.054.06c-.01.006-.017.01-.023.013a.17.17 0 0 1-.054.015H1.515a.17.17 0 0 1-.054-.015 1 1 0 0 1-.023-.013.2.2 0 0 1-.054-.06.18.18 0 0 1 .002-.183L8.244 2.073a.15.15 0 0 1 .054-.057zm1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z" />
                                <path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z" />
                            </svg>
                        </div>

                        <h4 class="fw-bold text-dark mb-2">Access Denied</h4>
                        <p class="text-secondary mb-0">Sorry, you do not have permission to view this section.</p>
                    </div>
                </div>
            </div>

            <!--Modal View Details-->
            <div class="modal fade" id="modalDetails" tabindex="-1" aria-labelledby="modalUpdateLabel" aria-hidden="true">
                <div class="modal-dialog w-70 mw-100 mx-40 modal-dialog-centered" role="document">
                    <div class="modal-content shadow border-0 rounded-0">

                        <div class="modal-header bg-light border-bottom-0 pt-4 px-sm-5 px-4">
                            <div class="w-100 text-center">
                                <label class="form-label text-muted small mb-1"><strong>Report ID</strong></label>
                                <input readonly id="rptcode" type="text" class="form-control-plaintext text-success text-center fw-bold fs-5 p-0">
                            </div>
                            <button type="button" class="btn-close position-absolute end-0 top-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <div class="modal-body px-sm-5 px-4 py-2">
                            <div class="row g-3 mx-3 mt-3">
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Region</strong></label>
                                    <input readonly id="region" type="text" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>KMUJ</strong></label>
                                    <input readonly id="kmuj" type="text" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Section</strong></label>
                                    <input readonly id="section" type="text" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong></strong></label>
                                    <input readonly id="" type="text" class="form-control-plaintext">
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Gang</strong></label>
                                    <input readonly id="gang" type="text" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>No. of Staff (Valid)</strong></label>
                                    <input readonly id="pax" type="text" class="form-control-plaintext">
                                </div>

                                <div class="col-12 my-4 mt-3">
                                    <div class="table-responsive">
                                        <table id="tableRep2" class="table table-striped table-hover align-middle mb-0 text-nowrap">
                                            <thead class="table-light">
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Work Date</strong></label>
                                    <input readonly type="text" id="workdate" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Line</strong></label>
                                    <input readonly type="text" id="linecond" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Category</strong></label>
                                    <input readonly type="text" id="category" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Category Details</strong></label>
                                    <input readonly type="text" id="categorydets" class="form-control-plaintext">
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Work Type</strong></label>
                                    <input readonly type="text" id="worktype" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Total</strong></label>
                                    <input readonly type="text" id="totalWork" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Unit</strong></label>
                                    <input readonly type="text" id="unit" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong></strong></label>
                                    <input readonly id="" type="text" class="form-control-plaintext">
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Effected KM (From)</strong></label>
                                    <input readonly type="text" id="KMfrom" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Effected KM (To)</strong></label>
                                    <input readonly type="text" id="KMto" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Total KM (meter)</strong></label>
                                    <input readonly type="text" id="totalKM" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong></strong></label>
                                    <input readonly id="" type="text" class="form-control-plaintext">
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Time Start</strong></label>
                                    <input readonly type="text" id="timeStart" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Time End</strong></label>
                                    <input readonly type="text" id="timeEnd" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Total Time</strong></label>
                                    <input readonly type="text" id="totalTime" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong></strong></label>
                                    <input readonly id="" type="text" class="form-control-plaintext">
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Work at Station</strong></label>
                                    <input readonly type="text" id="workStation" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong>Station Point</strong></label>
                                    <input readonly type="text" id="stPoint" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong></strong></label>
                                    <input readonly id="" type="text" class="form-control-plaintext">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label text-muted small mb-1"><strong></strong></label>
                                    <input readonly id="" type="text" class="form-control-plaintext">
                                </div>

                                <div class="col-12 mb-3">
                                    <label class="form-label text-muted small mb-1"><strong>Additional Note</strong></label>
                                    <input readonly type="text" id="notes" class="form-control-plaintext">
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer border-top-0 justify-content-center pb-4">
                            <button class="btn btn-secondary px-5" data-bs-dismiss="modal" type="button">Close</button>
                        </div>

                    </div>
                </div>
            </div>
            <!--Modal Delete Data-->
            <div class="modal fade" id="modalDelete" tabindex="-1" aria-labelledby="modalDeleteLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
                    <div class="modal-content">
                        <div class="modal-body text-center p-4">
                            <i class="fa fa-exclamation-circle fa-5x text-danger lh-1 mg-t-20 d-inline-block"></i>
                            <h3 class="text-danger">Warning! Are you sure? </h3>
                            <p class="mg-b-20 mg-x-20">You may not be able to recover this data.</p>
                            <h4 class="mt-5 text-danger">Report Number: </h4>
                            <input readonly id="reportno" data-id="" type="text" class="mb-3 form-control text-center bg-transparent border-0">

                            <button id="submitDelete" class="btn btn-danger mb-5" type="button">Delete</button>
                            <button class="btn btn-light mb-5" data-bs-dismiss="modal" aria-label="Close" type="button">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section scripts{
    <script src="~/assets/scripts/semua.js"></script>
    <script src="~/assets/scripts/dashboard.js"></script>
    <script src="~/assets/plugins/morris/morris.min.js"></script>
    <script src="~/assets/plugins/raphael/raphael.min.js"></script>
    <script src="~/assets/plugins/select2/select2.min.js"></script>
    <script src="~/assets/plugins/daterangepicker/daterangepicker.js"></script>

    <script type="text/javascript">

        $(document).ready(function () {
            listGang();
            listLnCondition();
            listCategory();
            listWorkType();
            listCatDetails();
            listWorkUnit();
            listLocation();
            checkSess();
            listRegion();
            listKMUJ();
            listSection();

            //CHECK USER LEVEL
            //user level == 1 & 5
            if (localStorage.getItem("lvlI") === "1" || localStorage.getItem("lvlI") === "5") {
                $("#contentAdmin").show();
                $("#contentNormal").hide();
                $("#contentOthers").hide();

                $('#txtDate').daterangepicker({
                    autoUpdateInput: false,
                    minYear: 2021,
                    locale: {
                        format: 'DD/MM/YYYY'
                    }
                });

                $('#txtDate').on('apply.daterangepicker', function (ev, picker) {
                    var sdate = picker.startDate.format('YYYY/MM/DD');
                    var edate = picker.endDate.format('YYYY/MM/DD');

                    $(this).val(picker.startDate.format('DD/MM/YYYY') + ' - ' + picker.endDate.format('DD/MM/YYYY'));

                    localStorage.setItem("selHar", sdate);
                    localStorage.setItem("selHarE", edate);
                });

                $("#region, #kmuj, #section").on('change', function () {
                    localStorage.removeItem("selHar");
                    localStorage.removeItem("selHarE");
                    $('#txtDate').val('');

                    var drp = $('#txtDate').data('daterangepicker');
                    drp.setStartDate(moment());
                    drp.setEndDate(moment());
                });

                $('#btnSearch').on('click', function () {
                    var rgn = $("#region option:selected").text();
                    var kmj = $("#kmuj option:selected").text();
                    var scn = $("#section option:selected").text();

                    localStorage.setItem("selRgn", rgn);
                    localStorage.setItem("selKmj", kmj);
                    localStorage.setItem("selScn", scn);

                    var sdate = localStorage.getItem("selHar") || "";
                    var edate = localStorage.getItem("selHarE") || "";

                    listReportsAdmin(rgn, kmj, scn, sdate, edate);

                    if (sdate !== "") {
                        salertSave('Searching for: ' + sdate + ' to ' + edate);
                    } else {
                        salertSave('Searching all dates for ' + rgn);
                    }
                });
            }

            //userlevel == 4
            else if (localStorage.getItem("lvlI") === "4") {
                $("#contentAdmin").hide();
                $("#contentNormal").show();
                $("#contentOthers").hide();

                $('#txtDate3').daterangepicker({
                    autoUpdateInput: false,
                    minYear: 2021,
                    locale: {
                        format: 'DD/MM/YYYY'
                    }
                });

                $('#txtDate3').on('apply.daterangepicker', function (ev, picker) {
                    var sdate = picker.startDate.format('YYYY/MM/DD');
                    var edate = picker.endDate.format('YYYY/MM/DD');

                    $(this).val(picker.startDate.format('DD/MM/YYYY') + ' - ' + picker.endDate.format('DD/MM/YYYY'));

                    localStorage.setItem("selHar", sdate);
                    localStorage.setItem("selHarE", edate);
                });

                $('#btnSearch3').on('click', function () {
                    var scn = localStorage.getItem("scn")
                    localStorage.setItem("selScn", scn);

                    var sdate = localStorage.getItem("selHar") || "";
                    var edate = localStorage.getItem("selHarE") || "";

                    listReportsNormal(scn, sdate, edate);

                    if (sdate !== "") {
                        salertSave('Searching for: ' + sdate + ' to ' + edate);
                    } else {
                        salertSave('Searching all dates for ' + scn);
                    }
                });
            }

            //not authorized user
            else {
                $("#contentAdmin").hide();
                $("#contentNormal").hide();
            }

            $("#datepicker, #dateEdit").datepicker({
                singleDatePicker: true,
                showDropdowns: true,
                minYear: 2021,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });        

            $("#workEdit").on('change', function () {
                wrk = $("#workEdit option:selected").text();
                localStorage.setItem("selWrk", wrk, this.value);
                listWorkUnit(localStorage.getItem("selWrk", this.value));
            });

            //show/hide work catergory - emegergency
            $("#catEdit").on('change', function () {
                if ($("#catEdit option:selected").val() == '1') {
                    $("#catEmerEdit").show();
                }
                else {
                    $("#catEmerEdit").hide();
                }
            });

            //auto calc total KM
            $('#startKM, #endKM').on('change', function () {
                validateKM();
            });

            //auto calc total time
            $('#startTime, #endTime').on('change', function () {
                validateTime();
            });

            //trigger modal delete and modal details
            $('#modalDetails, #modalDelete').on('show.bs.modal', function (e) {
                console.log(e.relatedTarget); // Log the element that triggered the modal

                var ids = $(e.relatedTarget).data('id');
                console.log('read ' + ids);
                rptDetails(ids);
            });

            //modal delete report
            $('#submitDelete').click(function () {
                var ids = $('#modalDelete').data('id'); // Retrieve the stored ID
                console.log('Read ID:', ids);
                if (ids) {
                    rptDelete(ids);
                } else {
                    console.error('No ID found for deletion.');
                }
            });

            //delete modal
            $('#modalDelete').on('show.bs.modal', function (e) {
                var ids = $(e.relatedTarget).data('id'); // Retrieve data-id from the triggering element
                console.log('Data-ID Retrieved:', ids); // Log the ID for debugging

                if (ids) {
                    // Store ID in modal for later use
                    $('#modalDelete').data('id', ids);

                    // Fetch and display report details
                    $.ajax({
                        url: linkDepan + "GetReportDetails?RptCode=" + ids,
                        type: 'GET',
                        type: 'GET',
                        dataType: 'json',
                        beforeSend: function (request) {
                            request.setRequestHeader("Token", localStorage.getItem('main'));
                        },
                        success: function (data) {
                            if (data && data[0] && data[0].rpt_code) {
                                $('#reportno').val(data[0].rpt_code); // Populate the report number
                            } else {
                                $('#reportno').val(''); // Clear the field if no data
                                console.error('Invalid data structure from API.');
                            }
                        },
                        error: function (xhr) {
                            console.error('Error fetching report details:', xhr.responseText);
                            swarning();
                        }
                    });
                } else {
                    console.error('No data-id found for modal.');
                }
            });

        });


        //show gang pax based on gang type
        function listGangPax(kmuj, section, gang) {
            if (typeof gang === "string") {
                gang = gang.split(/(?<=\d)(?=Gang)/);
            }

            if (Array.isArray(gang)) {
                var gangString = gang.join(",");

                $.ajax({
                    url: linkDepan + "GetGangPax",
                    data: {
                        Kmuj: kmuj,
                        Section: section,
                        Gang: gangString
                    },
                    dataType: "json",
                    beforeSend: function (request) {
                        request.setRequestHeader("Token", localStorage.getItem('main'));
                    },
                    success: function (data) {
                        if (data && data.length > 0) {
                            $('#gangno').val(data[0].count);
                        } else {
                            $('#gangno').val('0 pax');
                        }
                    },
                    error: function (error) {
                        $('#gangno').val("");
                    }
                });
            } else {
                return;
            }
        }


        //show report details bila dah tekan modalDetails
        function rptDetails(ids) {
            var reportno = $(".reportno" + ids).html();
            $.ajax({
                url: linkDepan + "GetAllFormDetails?RptCode=" + ids,
                type: 'GET',
                dataType: 'json',
                data: {},
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (data) {
                    $('#rptcode, #rptcode2').val(data[0].rpt_code);
                    $('#region, #region2').val(data[0].region_name);
                    $('#kmuj, #kmuj2').val(data[0].kmuj_name);
                    $('#section, #section2').val(data[0].section_name);
                    $('#gang').val(data[0].Gang);
                    $('#pax').val(data[0].daily_workers);
                    $('#workdate, #datepicker').val(data[0].daily_date);
                    $('#linecond').val(data[0].cond_name);
                    $('#category').val(data[0].category_name);
                    $('#categorydets').val(data[0].category_details);
                    $('#worktype').val(data[0].work_name);
                    $('#totalWork').val(data[0].daily_total);
                    $('#unit').val(data[0].daily_unit);
                    $('#KMfrom').val(data[0].effect_kmfrom);
                    $('#KMto').val(data[0].effect_kmto);
                    $('#totalKM').val(data[0].effect_kmtotal);
                    $('#timeStart').val(data[0].daily_timestart);
                    $('#timeEnd').val(data[0].daily_timelast);
                    $('#totalTime').val(data[0].daily_timetaken);
                    $('#notes').val(data[0].daily_additional);
                    $('#workStation').val(data[0].station);
                    $('#stPoint').val(data[0].station_point);

                    console.log('gang:', gang);
                    console.log('kmuj:', kmuj);  // Should now have correct value
                    console.log('section:', section);  // Should now have correct value

                    var kmuj = data[0].kmuj_name;
                    var section = data[0].section_name;
                    var gang = data[0].Gang;


                    // Call listReports2 with the fetched values
                    listReports2(kmuj, section, gang);
                },
                error: function (xhr) {
                    swarning();
                },
                complete: function () {
                }
            });
        }

        //show gang pax based on gang type
        function listGangPax(kmuj, section, gang) {
            if (typeof gang === "string") {
                gang = gang.split(/(?<=\d)(?=Gang)/);
            }

            if (Array.isArray(gang)) {
                var gangString = gang.join(",");

                $.ajax({
                    url: linkDepan + "GetGangPax",
                    data: {
                        Kmuj: kmuj,
                        Section: section,
                        Gang: gangString
                    },
                    dataType: "json",
