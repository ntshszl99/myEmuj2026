        //view modal --  show list staff yang kerja
        function listReports2(kmuj, section, gang) {
            var gangString = "";

            if (typeof gang === "string") {
                var cleanNumbers = gang.replace(/Gang/gi, '');
                var numberArray = cleanNumbers.split(',');
                var formattedGangs = numberArray.map(function (num) {
                    return "Gang " + num.trim();
                });

                gangString = formattedGangs.join(",");
            } else if (Array.isArray(gang)) {
                gangString = gang.join(",");
            }

            if (gangString && gangString.length > 0) {
                $.ajax({
                    url: linkDepan + "GetGListNormal?Kmuj=" + kmuj + "&Section=" + section + "&Gang=" + gangString,
                    type: 'GET',
                    dataType: 'json',
                    data: {},
                    beforeSend: function (request) {
                        request.setRequestHeader("Token", localStorage.getItem('main'));
                    },
                    success: function (response) {
                        try {
                            console.log("Server Response:", response);

                            var counter = 1;
                            $.fn.dataTable.ext.errMode = 'throw';
                            if ($.fn.dataTable.isDataTable('#tableRep2')) {
                                $('#tableRep2').DataTable().destroy();
                                $('#tableRep2').empty();
                            }

                            $('#tableRep2').DataTable({
                                responsive: true,
                                data: response,
                                columns: [
                                    { data: "Emplid" },
                                    { data: "Emplid" },
                                    { data: "Nama" },
                                    { data: "JobGrade" },
                                    { data: "JobDesc" },
                                    { data: "Gang" },
                                    { data: "cuti_name" },
                                ],
                                columnDefs: [
                                    {
                                        targets: -1,
                                        title: "Status",
                                        render: function (data) {
                                            return data == 'VALID'
                                                ? '<a class="text-success">' + data + ' <i class="ion-checkmark-circled"></i></a>'
                                                : '<a class="text-danger">' + data + ' <i class="ion-close-circled"></i></a>';
                                        }
                                    },
                                    { targets: -2, title: "Gang", render: function (data) { return data; } },
                                    { targets: -3, title: "Position", render: function (data) { return data; } },
                                    { targets: -4, title: "Grade", render: function (data) { return data; } },
                                    { targets: -5, title: "Name", render: function (data) { return data; } },
                                    { targets: -6, title: "Staff ID", render: function (data) { return data; } },
                                    { targets: -7, title: "No", render: function () { return counter++; } }
                                ],
                                createdRow: function (row, data, dataIndex) {
                                    $('td', row).addClass('text-nowrap align-middle');
                                }
                            });
                        } catch (error) {
                            console.error("Error parsing/binding table data:", error);
                        }
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        console.error("AJAX request failed:", textStatus, errorThrown);
                    }
                });
            }
        }


