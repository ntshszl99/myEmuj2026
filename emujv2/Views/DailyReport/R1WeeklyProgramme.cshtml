@section scripts{
    <link rel="stylesheet" href="https://cdn.datatables.net/fixedcolumns/4.3.0/css/fixedcolumns.dataTables.min.css">sho
    <script src="https://cdn.datatables.net/fixedcolumns/4.3.0/js/dataTables.fixedColumns.min.js"></script>
    <script src="~/assets/scripts/dashboard.js"></script>
    <script src="~/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="~/assets/plugins/select2/select2.min.js"></script>
    <script type="text/javascript">


        $(document).ready(function () {
            checkSess();
            listSection();
            listKMUJ();
            listReports();

            if (localStorage.getItem("lvlI") === "1" || localStorage.getItem("lvlI") === "5") {
                $("#contentAdmin").show();
                $("#contentOthers").hide();
                $("#contentNormal").hide();

                $("#kmuj, #section").on('change', function () {
                    localStorage.removeItem("selHar");
                    localStorage.removeItem("selHarE");
                    $('#txtDate').val('');

                    var drp = $('#txtDate').data('daterangepicker');
                    drp.setStartDate(moment());
                    drp.setEndDate(moment());
                });


                $('#kmuj').on('change', function (e, selectedSectionValue) {
                    var selectedKmuj = $(this).find('option:selected').text();
                    var selectedKmujVal = $(this).val();

                    console.log("Selected KMUJ Text:", selectedKmuj);

                    if (selectedKmujVal && selectedKmujVal !== "-0" && !selectedKmuj.includes("Select KMUJ")) {
                        $('#section').prop('disabled', false).trigger('change.select2');

                        listSection(selectedKmuj, selectedSectionValue);
                    } else {
                        $('#section')
                            .html('<option value="-0">Select Section</option>')
                            .prop('disabled', true)
                            .trigger('change')
                            .trigger('change.select2');
                    }
                });

                $('#btnSearch').on('click', function () {
                    var kmj = $("#kmuj option:selected").text();
                    var scn = $("#section option:selected").text();

                    localStorage.setItem("selKmj", kmj);
                    localStorage.setItem("selScn", scn);

                    var sdate = localStorage.getItem("selHar") || "";
                    var edate = localStorage.getItem("selHarE") || "";

                    listReports(kmj, scn, sdate, edate);

                    if (sdate !== "") {
                        salertSave('Searching for: ' + sdate + ' to ' + edate);
                    } else {
                        salertSave('Searching all dates for ' + rgn);
                    }
                });
            }

            else if (localStorage.getItem("lvlI") === "2" || localStorage.getItem("lvlI") === "3" || localStorage.getItem("lvlI") === "4") {
                $("#contentAdmin").hide();
                $("#contentOthers").hide();
                $("#contentNormal").show();

                $('#txtDateNormal').daterangepicker({
                    autoUpdateInput: false,
                    singleDatePicker: true,
                    minYear: 2021,
                    locale: {
                        format: 'DD/MM/YYYY'
                    }
                });

                $('#txtDateNormal').on('apply.daterangepicker', function (ev, picker) {
                    var newEndDate = moment(picker.startDate).add(7, 'days');
                    $(this).data('daterangepicker').setEndDate(newEndDate);

                    var sdate = picker.startDate.format('YYYY/MM/DD');
                    var edate = newEndDate.format('YYYY/MM/DD');

                    $(this).val(picker.startDate.format('DD/MM/YYYY') + ' - ' + newEndDate.format('DD/MM/YYYY'));

                    localStorage.setItem("selHar", sdate);
                    localStorage.setItem("selHarE", edate);
                });

                $('#btnSearchNormal').on('click', function () {
                    var scn = localStorage.getItem("scn");
                    localStorage.setItem("selScn", scn);

                    var kmj = localStorage.getItem("kmuj");
                    localStorage.setItem("selKmj", kmj);

                    var sdate = localStorage.getItem("selHar") || "";
                    var edate = localStorage.getItem("selHarE") || "";

                    // Run the report
                    listReports(kmj, scn, sdate, edate);

                    if (sdate !== "") {
                        salertSave('Searching for: ' + sdate + ' to ' + edate);
                    } else {
                        salertSave('Searching all dates for ' + rgn);
                    }
                });
            }
            else {
                $("#contentAdmin").hide();
                $("#contentOthers").show();
                $("#contentNormal").hide();
            }




            $('#txtDate, #txtDateNormal').daterangepicker({
                autoUpdateInput: false,
                singleDatePicker: true,
                minYear: 2021,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });

            $('#txtDate, #txtDateNormal').on('apply.daterangepicker', function (ev, picker) {
                var newEndDate = moment(picker.startDate).add(6, 'days');
                $(this).data('daterangepicker').setEndDate(newEndDate);

                var sdate = picker.startDate.format('YYYY/MM/DD');
                var edate = newEndDate.format('YYYY/MM/DD');

                $(this).val(picker.startDate.format('DD/MM/YYYY') + ' - ' + newEndDate.format('DD/MM/YYYY'));

                localStorage.setItem("selHar", sdate);
                localStorage.setItem("selHarE", edate);
            });

            

            $('#btnBulkSave, #btnBulkSaveNormal').on('click', function () {
                bulkSaveTotals();
            });


            // Use event delegation for dynamic DataTable content
            $('#tableRep, #tableRepNormal').on('click', '.attendance-toggle', function (e) {
                e.preventDefault();
                var btn = $(this);
                var span = btn.find('.attendance-text');
                var currentText = span.text().trim();

                // Define the cycle order
                const cycle = ['','CE', 'CT', 'TH', 'S'];

                // Determine next state
                var currentIndex = cycle.indexOf(currentText);
                var nextValue = cycle[(currentIndex + 1) % cycle.length];

                // Update UI
                span.text(nextValue);

                // Call your auto-save function
                autoSaveStaffAttendance(
                    btn.data('emplid'),
                    btn.data('date'),
                    nextValue
                );
            });

            $('#tableRep, #tableRepNormal').on('click', '.workplan-toggle', function () {
                var btn = $(this);
                var icon = btn.find('i');

                if (icon.hasClass('fa-blank')) {
                    icon.removeClass('fa-blank').addClass('fa-minus fa-rotate-90');
                } else if (icon.hasClass('fa-rotate-90')) {
                    icon.removeClass('fa-minus fa-rotate-90').addClass('fa-plus');
                } else if (icon.hasClass('fa-plus')) {
                    icon.removeClass('fa-plus').addClass('fa-minus');
                } else {
                    icon.removeClass('fa-minus').addClass('fa-blank');
                }

                autoSaveWorkPlan(
                    btn.data('emplid'),
                    btn.data('date'),
                    btn.data('workname'),
                    icon
                );
            });
        });


        function listSection(kmuj, selectedSectionValue) {
            $.ajax({
                url: linkDepan + "Kmuj?Kmuj=" + encodeURIComponent(kmuj), 
                dataType: "json",
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (data) {
                    $("#section").removeClass("is-invalid");

                    var auxArr = [];
                    auxArr.push("<option value='-0'>Select Section</option>");

                    if (data && data.length >= 1) {
                        $.each(data, function (index, value) {
                            auxArr.push("<option value='" + value.section_val + "'>" + value.section_name + "</option>");
                        });

                        $('#section').html('').append(auxArr.join(''));

                        if (selectedSectionValue) {
                            $('#section').val(selectedSectionValue);
                        }
                    } else {
                        $('#section')
                            .html('<option value="-0">Select Section</option>')
                            .addClass("is-invalid")
                            .prop('disabled', true);
                    }

                    $('#section').trigger('change').trigger('change.select2');
                },
                error: function (xhr) {
                    swarning();
                }
            });
        }

        function listKMUJ() {
            $.ajax({
                url: linkDepan + "KMUJList",
                dataType: "json",
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (data) {
                    if (data.length >= 1) {
                        auxArr = [];
                        $.each(data, function (index, value) {
                            auxArr[index] = "<option value='" + value.kmuj_id + "'>" + value.kmuj_name + "</option>";
                        });
                        $('#kmuj').append(auxArr.join(''));
                    } else {
                        $("#kmuj").addClass(" is-invalid");
                    }
                },
                error: function (xhr) {
                    swarning();
                },
                complete: function () { }
            });
        }

        function autoSaveWorkPlan(emplid, workDate, workName, icon) {
            // 1. Determine the plan code for the individual row
            let planCode = "pl";
            if (icon.hasClass('fa-plus')) planCode = "dp";
            else if (icon.hasClass('fa-minus')) planCode = "up";
            else if (icon.hasClass('fa-rotate-90')) planCode = "pl";

            let payload = {
                StaffNo: emplid,
                Date: workDate,
                WorkName: workName,
                PlanCode: planCode,
                UpdBy: localStorage.getItem('usrI')
            };
            console.log(payload);

            // AJAX 1: Update ONLY the individual staff record
            $.ajax({
                url: linkDepan + "UpdateWorkPlan",
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (response) {
                    console.log(`Individual Saved: ${emplid} -> ${planCode}`);
                }
            });
        }

        function autoSaveStaffAttendance(emplid, workDate, cutiCode) {
            let payload = {
                StaffNo: emplid,
                Date: workDate,
                CutiCode: cutiCode, // Maps directly to your codes (CA, CT, TH, etc.)
                UpdBy: localStorage.getItem('usrI')
            };

            $.ajax({
                url: linkDepan + "UpdateStaffLeave", // Ensure this matches your API route
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (response) {
                    console.log(`Attendance Saved: ${emplid} on ${workDate} as ${cutiCode}`);
                },
                error: function () {
                    alert("Failed to save attendance.");
                }
            });
        }

        function bulkSaveTotals() {
            let allPayloads = [];
            let uniqueDates = [];

            $('[data-date]').each(function () {
                let date = $(this).attr('data-date');
                if (date && date.trim() !== "") {
                    date = date.trim();
                    if (uniqueDates.indexOf(date) === -1) {
                        uniqueDates.push(date);
                    }
                }
            });

            if (uniqueDates.length === 0) {
                console.error("No dates identified in the UI.");
                swal.fire({ title: 'Warning!', text: 'Please select or view the dates you wish to update.', icon: 'warning' });
                return;
            }

            uniqueDates.forEach(function (d) {
                allPayloads.push({ Date: d });
            });

            $.ajax({
                url: linkDepan + "UpdateWorkPlanTotal",
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(allPayloads),
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (response) {
                    let res = JSON.parse(response);
                    if (res.status === "00") {
                        swal.fire({ title: 'Success!', text: 'Updated ' + uniqueDates.length + ' dates successfully.', icon: 'success' });
                    } else {
                        swal.fire({ title: 'Error!', text: 'Update failed ' + res.StatusDetail, icon: 'error' });
                    }
                }
            });
        }



        function listReports(kmuj, section, sdate, edate) {
            $.ajax({
                url: linkDepan + "GetR1?Kmuj=" + kmuj + "&Section=" + section + "&SDate=" + sdate + "&Edate=" + edate,
                type: 'GET',
                dataType: 'json',
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (data) {
                    if ($.fn.dataTable.isDataTable('#tableRep, #tableRepNormal')) {
                        $('#tableRep, #tableRepNormal').DataTable().clear().destroy();
                    }

                    $('#tableMetadataView').remove();
                    $('#tableRep, #tableRepNormal thead').empty();
                    $('#tableRep, #tableRepNormal tbody').empty();
                    $('#tableRep, #tableRepNormal tfoot').remove();

                    const startDate = moment(sdate, ['YYYY/MM/DD', 'YYYY-MM-DD']);
                    const endDate = moment(edate, ['YYYY/MM/DD', 'YYYY-MM-DD']);
                    const weekNumber = startDate.isValid() ? startDate.week() : "";
                    const weekEndingStr = endDate.isValid() ? endDate.format('DD/MM/YYYY') : edate;

                    const uniquework_name = [...new Set(data.map(item => item.work_name))];

                    let headerRow1 = ['Staff No', 'Name', 'Designation'];
                    headerRow1.push('ATTENDANCE', '', '', '', '', '', '');
                    uniquework_name.forEach(desc => {
                        headerRow1.push(desc, '', '', '', '', '', '');
                    });

                    let headerRow2 = ['', '', ''];
                    for (let i = 0; i < (1 + uniquework_name.length); i++) {
                        for (let j = 0; j < 7; j++) {
                            headerRow2.push(moment(startDate).add(j, 'days').format('DD'));
                        }
                    }

                    let thead = '<tr><th rowspan="2">Staff No</th><th rowspan="2">Name</th><th rowspan="2">Designation</th>';
                    thead += `<th colspan="7">ATTENDANCE</th>`;
                    uniquework_name.forEach(desc => { thead += `<th colspan="7">${desc}</th>`; });
                    thead += '</tr><tr>';
                    for (let i = 0; i < (1 + uniquework_name.length); i++) {
                        for (let j = 0; j < 7; j++) {
                            thead += `<th>${moment(startDate).add(j, 'days').format('DD')}</th>`;
                        }
                    }
                    thead += '</tr>';
                    $('#tableRep, #tableRepNormal thead').html(thead);

                    // Statistics initializers (Added 'cs' array)
                    let attStats = { valid: Array(7).fill(0), al: Array(7).fill(0), mc: Array(7).fill(0), ab: Array(7).fill(0), cs: Array(7).fill(0) };
                    let workStats = {};
                    uniquework_name.forEach(name => { workStats[name] = { dp: Array(7).fill(0), up: Array(7).fill(0) }; });
                    let dailyAdditionalMap = {};
                    const trackedDailyAttendance = {};

                    const groupedData = data.reduce((acc, item) => {
                        const dateKey = moment(item.daily_date).format('YYYY-MM-DD');
                        const empId = item.Emplid;
                        const trackingKey = `${empId}_${dateKey}`;
                        const dayIndex = moment(item.daily_date).diff(startDate, 'days');

                        if (item.daily_additional) {
                            dailyAdditionalMap[`${dateKey}_${item.work_name}`] = item.daily_additional;
                        }
                        if (!acc[empId]) {
                            acc[empId] = { Nama: item.Nama, JobDesc: item.JobDesc, work_data: {}, attendance_data: {} };
                        }

                        acc[empId].attendance_data[dateKey] = { leave: item.leaveType_id };

                        if (!acc[empId].work_data[item.work_name]) {
                            acc[empId].work_data[item.work_name] = {};
                        }

                        let rawCode = (item.work_plan_type_code === null) ? "pl" : String(item.work_plan_type_code).toLowerCase().trim();
                        if (rawCode === "") rawCode = "pl";
                        acc[empId].work_data[item.work_name][dateKey] = rawCode;

                        if (dayIndex >= 0 && dayIndex < 7) {
                            if (rawCode === "dp" || rawCode === "up") {
                                if (workStats[item.work_name]) workStats[item.work_name][rawCode][dayIndex]++;
                            }
                            if (!trackedDailyAttendance[trackingKey]) {
                                const l = item.leaveType_id ? String(item.leaveType_id).toLowerCase().trim() : "valid";

                                if (l === "al" || l === "ct") {
                                    attStats.al[dayIndex]++;
                                } else if (l === "mc" || l === "s") {
                                    attStats.mc[dayIndex]++;
                                } else if (l === "ab" || l === "th") {
                                    attStats.ab[dayIndex]++;
                                } else if (l === "cs" || l === "ce") { // Track Cuti Ehsan stats
                                    attStats.cs[dayIndex]++;
                                } else {
                                    attStats.valid[dayIndex]++;
                                }

                                trackedDailyAttendance[trackingKey] = true;
                            }
                        }
                        return acc;
                    }, {});

                    let tbody = '';
                    for (let staffNo in groupedData) {
                        tbody += `<tr><td>${staffNo}</td><td>${groupedData[staffNo].Nama}</td><td>${groupedData[staffNo].JobDesc}</td>`;

                        // Attendance Columns Processing Loop
                        for (let i = 0; i < 7; i++) {
                            let d = moment(startDate).add(i, 'days').format('YYYY-MM-DD');
                            let dayInfo = groupedData[staffNo].attendance_data[d];
                            let displayValue = "";
                            let leaveTypeTracking = "valid";
                            let isClickable = false;

                            // Updated validation: requires record existence AND active leave profile content to toggle
                            if (dayInfo && dayInfo.leave !== undefined && dayInfo.leave !== null && String(dayInfo.leave).trim() !== "") {
                                isClickable = true;
                                const leave = String(dayInfo.leave).toLowerCase().trim();

                                if (leave === "al" || leave === "ct") {
                                    displayValue = "CT";
                                    leaveTypeTracking = "al";
                                } else if (leave === "mc" || leave === "s") {
                                    displayValue = "S";
                                    leaveTypeTracking = "mc";
                                } else if (leave === "ab" || leave === "th") {
                                    displayValue = "TH";
                                    leaveTypeTracking = "ab";
                                } else if (leave === "cs" || leave === "ce") {
                                    displayValue = "CE";
                                    leaveTypeTracking = "cs";
                                } else if (leave === "ca") {
                                    displayValue = "CA";
                                    leaveTypeTracking = "valid";
                                } else if (leave !== "" && leave !== "valid") {
                                    displayValue = dayInfo.leave.toUpperCase();
                                    leaveTypeTracking = "valid";
                                }
                            } else {
                                isClickable = false;
                            }

                            let disabledAttr = isClickable ? "" : 'disabled="disabled"';
                            let cursorStyle = isClickable ? "cursor:pointer;" : "cursor:not-allowed; opacity: 0.65; pointer-events: none;";

                            tbody += `<td>
                        <a class="btn attendance-toggle" 
                           data-emplid="${staffNo}" 
                           data-date="${d}" 
                           data-leavetype="${leaveTypeTracking}"
                           ${disabledAttr}
                           style="display:block; ${cursorStyle}">
                           <span class="attendance-text">${displayValue}</span>
                        </a>
                    </td>`;
                        }

                        // Workplan Columns Loop
                        uniquework_name.forEach(wn => {
                            for (let i = 0; i < 7; i++) {
                                let d = moment(startDate).add(i, 'days').format('YYYY-MM-DD');
                                if (groupedData[staffNo].work_data[wn] && groupedData[staffNo].work_data[wn].hasOwnProperty(d)) {
                                    let currentCodeVal = groupedData[staffNo].work_data[wn][d];
                                    let iconClass = "fa-minus fa-rotate-90";
                                    if (currentCodeVal === "dp") iconClass = "fa-plus";
                                    else if (currentCodeVal === "up") iconClass = "fa-minus";
                                    tbody += `<td><a class="btn workplan-toggle" data-emplid="${staffNo}" data-date="${d}" data-workname="${wn}" data-code="${currentCodeVal}"><i class="fa ${iconClass}"></i></a></td>`;
                                } else {
                                    tbody += `<td></td>`;
                                }
                            }
                        });
                        tbody += `</tr>`;
                    }

                    // Updated Footer Mapping to include TOTAL CUTI EHSAN
                    const footerMapping = [
                        { label: 'TOTAL ATTENDANCE', attKey: 'valid', type: 'attendance' },
                        { label: 'TOTAL YEARLY LEAVE', attKey: 'al', type: 'leave' },
                        { label: 'TOTAL SICK LEAVE', attKey: 'mc', type: 'leave' },
                        { label: 'TOTAL ABSENT', attKey: 'ab', type: 'leave' },
                        { label: 'TOTAL CUTI EHSAN', attKey: 'cs', type: 'leave' }
                    ];

                    footerMapping.forEach(rowConfig => {
                        tbody += `<tr class="summary-row" style="font-weight:bold; background-color:#ffffff !important;">` +
                            `<td class="merged-style-left">${rowConfig.label}</td>` +
                            `<td class="merged-style-middle"></td>` +
                            `<td class="merged-style-right"></td>`;

                        attStats[rowConfig.attKey].forEach((val, i) => {
                            tbody += `<td class="summary-att-cell" data-day="${i}" data-key="${rowConfig.attKey}">${val === 0 ? '' : val}</td>`;
                        });

                        uniquework_name.forEach(wn => {
                            for (let i = 0; i < 7; i++) {
                                let displayVal = "";
                                if (rowConfig.label === 'TOTAL ATTENDANCE') {
                                    let total = (workStats[wn].dp[i] || 0) + (workStats[wn].up[i] || 0);
                                    displayVal = total > 0 ? total : "";
                                }
                                tbody += `<td class="total-cell" data-rowtype="${rowConfig.type}" data-workname="${wn}" data-day="${i}">${displayVal}</td>`;
                            }
                        });
                        tbody += '</tr>';
                    });

                    tbody += `<tr class="summary-row" style="font-weight:bold; background-color:#ffffff !important;">` +
                        `<td class="merged-style-left">ADDITIONAL INFO</td>` +
                        `<td class="merged-style-middle"></td>` +
                        `<td class="merged-style-right"></td>`;

                    for (let i = 0; i < 7; i++) { tbody += `<td></td>`; }
                    uniquework_name.forEach((wn) => {
                        for (let i = 0; i < 7; i++) {
                            let d = moment(startDate).add(i, 'days').format('YYYY-MM-DD');
                            let info = dailyAdditionalMap[`${d}_${wn}`] || "";
                            tbody += `<td><div class="vertical-text">${info}</div></td>`;
                        }
                    });
                    tbody += '</tr>';

                    $('#tableRep, #tableRepNormal tbody').html(tbody);

                    const whiteRowStylePatch = `
                <style id="forceWhiteTableLayout">
                    #tableRep , #tableRep tbody tr, #tableRep tbody td, #tableRep tbody tr.summary-row td {
                        background-color: #ffffff !important;
                    }
                    .DTFC_LeftBodyWrapper, .DTFC_LeftBodyWrapper table, .DTFC_LeftBodyWrapper tbody tr td {
                        background-color: #ffffff !important;
                    }
                    #tableRep thead th, 
                    .dataTables_scrollHead table thead th,
                    .DTFC_LeftHeadWrapper table thead th {
                        text-align: center !important;
                        vertical-align: middle !important;
                    }
                    .merged-style-left {
                        border-right: none !important;
                        text-align: left !important;
                    }
                    .merged-style-middle {
                        border-left: none !important;
                        border-right: none !important;
                    }
                    .merged-style-right {
                        border-left: none !important;
                    }
                </style>
            `;
                    $('#forceWhiteTableLayout').remove();
                    $('head').append(whiteRowStylePatch);

                    function getFooterDataArray() {
                        let rows = [];
                        footerMapping.forEach(rowConfig => {
                            let fullRow = [rowConfig.label, '', ''];
                            attStats[rowConfig.attKey].forEach(val => { fullRow.push(val === 0 ? '' : String(val)); });
                            uniquework_name.forEach(wn => {
                                for (let i = 0; i < 7; i++) {
                                    let displayVal = "";
                                    if (rowConfig.label === 'TOTAL ATTENDANCE') {
                                        let total = (workStats[wn].dp[i] || 0) + (workStats[wn].up[i] || 0);
                                        displayVal = total > 0 ? String(total) : "";
                                    }
                                    fullRow.push(displayVal);
                                }
                            });
                            rows.push(fullRow);
                        });

                        let addInfoRow = ['ADDITIONAL INFO', '', ''];
                        for (let i = 0; i < 7; i++) { addInfoRow.push(''); }
                        uniquework_name.forEach((wn) => {
                            for (let i = 0; i < 7; i++) {
                                let d = moment(startDate).add(i, 'days').format('YYYY-MM-DD');
                                addInfoRow.push(dailyAdditionalMap[`${d}_${wn}`] || "");
                            }
                        });
                        rows.push(addInfoRow);
                        return rows;
                    }

                    function getCleanCellData(node) {
                        let $node = $(node);
                        let $toggleBtn = $node.find('.workplan-toggle');
                        if ($toggleBtn.length > 0) {
                            let code = $toggleBtn.data('code');
                            if (code === 'dp') return '+';
                            if (code === 'up') return '-';
                            return '';
                        }
                        let $span = $node.find('span');
                        if ($span.length > 0) return $span.text().trim();
                        return $node.text().trim();
                    }

                    function getExcelColumnName(colIdx) {
                        let alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
                        let columnName = "";
                        while (colIdx >= 0) {
                            columnName = alphabet[colIdx % 26] + columnName;
                            colIdx = Math.floor(colIdx / 26) - 1;
                        }
                        return columnName;
                    }

                    let tableElement = $('#tableRep, #tableRepNormal').addClass('table table-bordered').DataTable({
                        dom: '<"selected-values"fB>rtip',
                        buttons: [
                            {
                                extend: 'csv',
                                filename: function () { return 'WeeklyProgramme(R1) ' + kmuj + '-' + section + '_' + sdate + '_to_' + edate; },
                                header: false,
                                exportOptions: {
                                    rows: ':visible',
                                    format: { body: function (d, r, c, n) { return getCleanCellData(n); } }
                                },
                                customize: function (csv) {
                                    let lines = csv.split('\n');
                                    lines = lines.slice(0, lines.length - (footerMapping.length + 2));
                                    let cleanBody = lines.join('\n');

                                    let customHeader = headerRow1.join(",") + "\n" + headerRow2.join(",") + "\n";
                                    let baseCsv = customHeader + cleanBody + "\n";
                                    let footerRows = getFooterDataArray();
                                    let footerCsv = "";
                                    footerRows.forEach(row => {
                                        let escapedRow = row.map(val => {
                                            let stringVal = (val === null || val === undefined) ? "" : String(val);
                                            return `"${stringVal.replace(/"/g, '""')}"`;
                                        });
                                        footerCsv += escapedRow.join(",") + "\n";
                                    });
                                    return baseCsv + footerCsv;
                                }
                            },
                            {
                                extend: 'excel',
                                filename: function () { return 'WeeklyProgramme(R1) ' + kmuj + '-' + section + '_' + sdate + '_to_' + edate; },
                                title: null,
                                header: false,
                                exportOptions: {
                                    rows: ':visible',
                                    format: { body: function (d, r, c, n) { return getCleanCellData(n); } }
                                },
                                customize: function (xlsx) {
                                    let sheet = xlsx.xl.worksheets['sheet1.xml'];
                                    let numCols = headerRow1.length;

                                    let row1Xml = '<row r="1">';
                                    let row2Xml = '<row r="2">';
                                    for (let c = 0; c < numCols; c++) {
                                        let colRef = getExcelColumnName(c);
                                        let val1 = headerRow1[c] !== undefined && headerRow1[c] !== null ? String(headerRow1[c]) : '';
                                        let val2 = headerRow2[c] !== undefined && headerRow2[c] !== null ? String(headerRow2[c]) : '';
                                        row1Xml += `<c t="inlineStr" r="${colRef}1"><is><t><![CDATA[${val1}]]></t></is></c>`;
                                        row2Xml += `<c t="inlineStr" r="${colRef}2"><is><t><![CDATA[${val2}]]></t></is></c>`;
                                    }
                                    row1Xml += '</row>'; row2Xml += '</row>';

                                    let finalBodyRowIdx = 2;
                                    $('row', sheet).each(function () {
                                        let currentDocRow = parseInt($(this).attr('r'));
                                        let newDocRow = currentDocRow + 2;
                                        $(this).attr('r', newDocRow);
                                        if (newDocRow > finalBodyRowIdx) { finalBodyRowIdx = newDocRow; }
                                        $('c', this).each(function () {
                                            let cellRef = $(this).attr('r');
                                            let colPart = cellRef.match(/[A-Z]+/)[0];
                                            $(this).attr('r', colPart + newDocRow);
                                        });
                                    });

                                    let sheetData = sheet.getElementsByTagName('sheetData')[0];
                                    $('row', sheetData).each(function () {
                                        let rIdx = parseInt($(this).attr('r'));
                                        if (rIdx > (finalBodyRowIdx - (footerMapping.length + 1))) { $(this).remove(); }
                                    });

                                    let currentExcelRow = (finalBodyRowIdx - (footerMapping.length + 1)) + 1;
                                    let footerRowsData = getFooterDataArray();

                                    footerRowsData.forEach((rowArr) => {
                                        let footerRowXml = `<row r="${currentExcelRow}">`;
                                        rowArr.forEach((cellVal, cIdx) => {
                                            let colRef = getExcelColumnName(cIdx);
                                            let cleanVal = (cellVal === null || cellVal === undefined) ? "" : String(cellVal).trim();
                                            let isNumeric = cleanVal !== "" && /^\d+$/.test(cleanVal);
                                            if (isNumeric) {
                                                footerRowXml += `<c r="${colRef}${currentExcelRow}"><v>${cleanVal}</v></c>`;
                                            } else {
                                                footerRowXml += `<c t="inlineStr" r="${colRef}${currentExcelRow}"><is><t><![CDATA[${cleanVal}]]></t></is></c>`;
                                            }
                                        });
                                        footerRowXml += `</row>`;
                                        let parser = new DOMParser();
                                        sheetData.appendChild(sheet.importNode(parser.parseFromString(footerRowXml, "text/xml").documentElement, true));
                                        currentExcelRow++;
                                    });

                                    let parser = new DOMParser();
                                    sheetData.insertBefore(sheet.importNode(parser.parseFromString(row2Xml, "text/xml").documentElement, true), sheetData.firstChild);
                                    sheetData.insertBefore(sheet.importNode(parser.parseFromString(row1Xml, "text/xml").documentElement, true), sheetData.firstChild);
                                }
                            }
                        ],
                        responsive: false,
                        autoWidth: false,
                        paging: false,
                        ordering: false,
                        fixedColumns: {
                            left: 3
                        },
                        columnDefs: [
                            { targets: '_all', className: 'dt-center head-center' }
                        ],
                        createdRow: function (row) {
                            if ($(row).hasClass('summary-row')) {
                                $('td', row).css('background-color', '#ffffff');
                                $('td:gt(2)', row).addClass('text-nowrap align-middle text-center');
                            } else {
                                $('td', row).addClass('text-nowrap align-middle text-center');
                            }
                        },
                        initComplete: function () {
                            setTimeout(() => {
                                let api = this.api();
                                api.columns.adjust();
                            }, 200);
                        }
                    });

                    let metadataHtml = `
                <div id="tableMetadataView" class="mt-2 mb-3 p-2" style="font-size: 15px; border-radius: 0 4px 4px 0;">
                    <div style="display: flex; justify-content: flex-end; align-items: flex-start; width: 100%;">
                        <div style="text-align: right; padding-right: 15px;">
                            <div style="margin-bottom: 4px;"><strong>Week No :</strong> ${weekNumber}</div>
                            <div><strong>Week Ending :</strong> ${weekEndingStr}</div>
                        </div>
                    </div>
                </div>
            `;
                    $('.selected-values').after(metadataHtml);

                    // ==========================================
                    // 1. ATTENDANCE DYNAMIC TOGGLE HANDLER
                    // ==========================================
                    $(document).off('click', '.attendance-toggle').on('click', '.attendance-toggle', function (e) {
                        e.preventDefault();
                        const $btn = $(this);

                        if ($btn.attr('disabled')) {
                            return false;
                        }

                        const $span = $btn.find('.attendance-text');
                        const date = $btn.data('date');
                        const empId = $btn.data('emplid');
                        const dayIndex = moment(date).diff(startDate, 'days');
                        const oldType = $btn.data('leavetype') || 'valid';

                        let newType, newDisplay;
                        if (oldType === 'valid') { newType = 'al'; newDisplay = 'CT'; }
                        else if (oldType === 'al') { newType = 'mc'; newDisplay = 'S'; }
                        else if (oldType === 'mc') { newType = 'ab'; newDisplay = 'TH'; }
                        else if (oldType === 'ab') { newType = 'cs'; newDisplay = 'CE'; }
                        else { newType = 'valid'; newDisplay = ''; }

                        attStats[oldType][dayIndex]--;
                        attStats[newType][dayIndex]++;

                        $btn.data('leavetype', newType);
                        $span.text(newDisplay);

                        footerMapping.forEach(f => {
                            let val = attStats[f.attKey][dayIndex];
                            $(`.summary-att-cell[data-day="${dayIndex}"][data-key="${f.attKey}"]`).text(val === 0 ? '' : val);
                        });

                        let dbCutiCode = "valid";
                        if (newType === 'al') dbCutiCode = "CT";
                        else if (newType === 'mc') dbCutiCode = "S";
                        else if (newType === 'ab') dbCutiCode = "TH";
                        else if (newType === 'cs') dbCutiCode = "CS";

                        autoSaveStaffAttendance(empId, date, dbCutiCode);
                    });

                    // ==========================================
                    // 2. WORKPLAN TOGGLE HANDLER
                    // ==========================================
                    $(document).off('click', '.workplan-toggle').on('click', '.workplan-toggle', function (e) {
                        e.preventDefault();
                        const $btn = $(this); const $icon = $btn.find('i');
                        const empId = $btn.data('emplid'); const date = $btn.data('date'); const workName = $btn.data('workname');
                        let oldCode = $btn.data('code'); const dayIndex = moment(date).diff(startDate, 'days');
                        let newCode, newIcon;

                        if (oldCode === "pl" || !oldCode || oldCode === "null") { newCode = "dp"; newIcon = "fa-plus"; }
                        else if (oldCode === "dp") { newCode = "up"; newIcon = "fa-minus"; }
                        else { newCode = "pl"; newIcon = "fa-minus fa-rotate-90"; }

                        if (oldCode === "dp" || oldCode === "up") workStats[workName][oldCode][dayIndex]--;
                        if (newCode === "dp" || newCode === "up") workStats[workName][newCode][dayIndex]++;

                        $btn.data('code', newCode); $icon.removeClass('fa-plus fa-minus fa-rotate-90').addClass(newIcon);
                        const newTotal = (workStats[workName].dp[dayIndex] || 0) + (workStats[workName].up[dayIndex] || 0);

                        const $attendanceFooterCells = $(`.total-cell[data-rowtype="attendance"][data-workname="${workName}"][data-day="${dayIndex}"]`);
                        $attendanceFooterCells.text(newTotal > 0 ? newTotal : "");

                        autoSaveWorkPlan(empId, date, workName, $icon);
                    });
                },
                error: function () { alert("Failed to load reports."); }
            });
        }





    </script>
}



