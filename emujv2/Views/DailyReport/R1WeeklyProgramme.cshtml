<style>
    /* 1. The container for the rotated text */
    .vertical-text {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        white-space: normal;
        display: inline-block;
        /* Font size & Style */
        font-size: 13px;
        text-transform: initial;
        line-height: 1.3;
        /* Layout Control */
        /* Changed width to 100% so it matches the column width automatically */
        width: 100%;
        max-width: 35px; /* Adjust this to match your header column width */
        /* Ensures vertical length matches the row height */
        height: 580px;
        /* Wrapping logic */
        word-break: break-word;
        overflow: hidden;
        box-sizing: border-box;
    }

    /* 2. The table cells in the footer */
    .additional-info-row td {
        vertical-align: middle !important;
        text-align: center;
        height: 600px !important;
        padding: 5px 2px !important; /* Reduced side padding */
        background-color: #fef9e7;
        /* Essential for fitting content */
        white-space: normal !important;
        overflow: hidden;
    }

    /* Fix background bleed issues across cloned elements */
    .DTFC_LeftHeadWrapper th,
    .DTFC_LeftBodyWrapper td,
    table.dataTable th.dtfc-fixed-left,
    table.dataTable td.dtfc-fixed-left {
        background-color: #ffffff !important;
        z-index: 5;
    }

    /* Maintain footer background consistency */
    #footerData tr.footer-row td.dtfc-fixed-left {
        background-color: #f9f9f9 !important;
    }



</style>

