@{
    ViewBag.Title = "RegisteredUser";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    /* Ensure modal doesn't block the alert */
    .modal-backdrop {
        z-index: 1040 !important;
    }

    .swal2-container {
        z-index: 200000 !important; /* Higher than any standard Bootstrap modal */
    }
</style>
<div class="app-content main-content">
    <div class="side-app">
        <div class="container-fluid main-container">

            <!--Page header-->
            <div class="page-header">
                <div class="page-leftheader">
                    <h4 class="page-title">Registered Users' List</h4>
                </div>
            </div>
            <!--End Page header-->

            <div class="" id="contentAdmin">
                <div class="card">
                    <div class="card-body">
                        <div class="col-lg-12">
                            <div class="table-responsive table-lg">
                                <div class="card-body">
                                    <div class="col-lg-12">
                                        <div class="table-responsive table-lg">
                                            <div class="mb-5 d-flex justify-content-start">
                                                <a class="btn btn-success" data-bs-target="#modalTambah" data-bs-toggle="modal" href="javascript:void(0)">Add New User</a>
                                            </div>
                                            <table id="tableRep" class="table table-striped table-bordered text-nowrap">
                                                <thead>
                                                </thead>
                                                <tbody></tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <div class="container-fluid" id="contentOthers">
                <div class="card border-0 shadow-sm ">
                    <div class="card-body p-4 text-center mt-5 mb-5">
                        <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-circle p-3 mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-exclamation-triangle" viewBox="0 0 16 16">
                                <path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.15.15 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.2.2 0 0 1-.054.06c-.01.006-.017.01-.023.013a.17.17 0 0 1-.054.015H1.515a.17.17 0 0 1-.054-.015 1 1 0 0 1-.023-.013.2.2 0 0 1-.054-.06.18.18 0 0 1 .002-.183L8.244 2.073a.15.15 0 0 1 .054-.057zm1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z" />
                                <path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z" />
                            </svg>
                        </div>

                        <h4 class="fw-bold text-dark mb-2">Access Denied</h4>
                        <p class="text-secondary mb-0">Sorry, you do not have permission to view this section.</p>
                    </div>
                </div>
            </div>

            <!--Modal Add User-->
            <div class="modal fade" id="modalTambah" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered" style="max-width: 1350px; width: 95%;" role="document">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-body p-5">

                            <div class="text-center mb-5 mt-5">
                                <h3 class="text-success fw-bold mb-2">Add New User</h3>
                                <h4 class="text-muted">Fill in the staff ID to auto-populate information and assign access levels.</h4>
                            </div>

                            <div class="row g-5 text-start">
                                <div class="col-lg-6 border-end pe-lg-5">
                                    <h5 class="mb-4 text-secondary fw-semibold">Staff Information</h5>

                                    <div class="mb-3">
                                        <label for="staffID" class="form-label text-muted small mb-1">Staff ID</label>
                                        <select id="staffID" class="form-control form-select select2">
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label for="staffname" class="form-label text-muted small mb-1">Staff Name</label>
                                        <input readonly id="staffname" type="text" class="form-control bg-light">
                                    </div>

                                    <div class="mb-3">
                                        <label for="position" class="form-label text-muted small mb-1">Designation</label>
                                        <input readonly id="position" type="text" class="form-control bg-light">
                                    </div>

                                    <div class="mb-3">
                                        <label for="region" class="form-label text-muted small mb-1">Region</label>
                                        <input readonly id="region" type="text" class="form-control bg-light">
                                    </div>
                                </div>

                                <div class="col-lg-6 ps-lg-5 d-flex flex-column justify-content-between">
                                    <div>
                                        <h5 class="mb-4 text-success fw-semibold">Assign Fields</h5>

                                        <div class="p-4 rounded-3 bg-success-transparent-2 border border-success border-opacity-10">

                                            <div class="mb-2">
                                                <label for="userlevel" class="form-label fw-medium mb-1">Level Entitle</label>
                                                <select id="userlevel" class="form-control form-select select2" required>
                                                    <option value="-0">.: Select User Level :.</option>
                                                </select>
                                            </div>

                                            <div id="kmujdw" class="mb-4">
                                                <label for="kmuj" class="form-label fw-medium mb-1">KMUJ</label>
                                                <select id="kmuj" class="form-control form-select select2" required>
                                                    <option value="-0">.: Select Kmuj :.</option>
                                                </select>
                                            </div>

                                            <div id="sectiondw" class="mb-4">
                                                <label for="section" class="form-label fw-medium mb-1">Section</label>
                                                <select id="section" class="form-control form-select select2" required>
                                                    <option value="-0">.: Select Section :.</option>
                                                </select>
                                            </div>



                                        </div>
                                    </div>

                                    <div class="d-flex gap-2 justify-content-end mt-5 pt-3">
                                        <button type="button" class="btn btn-light px-4" id="cancel" data-bs-dismiss="modal">Cancel</button>
                                        <button type="button" class="btn btn-success px-4" id="submitNew">Submit</button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>




            <!--Modal User Details-->
            <div class="modal fade" id="modalDetails" tabindex="-1" aria-labelledby="modalUpdateLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered" style="max-width: 1350px; width: 95%;" role="document">
                    <div class="modal-content border-0 shadow-lg">
                        <div class="modal-body p-5">
                            <div class="text-center mb-5 mt-5">
                                @*<i class="fe fe-check-circle text-success lh-1 d-inline-block mb-2" style="font-size: 4em;"></i>
                            <h3 class="text-success fw-bold">Confirm Action</h3>*@
                                <h4 class="text-muted">Are you sure you want to update this staff data?</h4>
                            </div>
                            <div class="row g-5 text-start">
                                <div class="col-lg-6 border-end pe-lg-5">
                                    <h5 class="mb-4 text-secondary fw-semibold">Staff Information</h5>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small mb-1">Staff ID</label>
                                        <input readonly id="staffID2" type="text" class="form-control bg-light">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small mb-1">Staff Name</label>
                                        <input readonly id="staffname2" type="text" class="form-control bg-light">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small mb-1">Department</label>
                                        <input readonly id="dept2" type="text" class="form-control bg-light">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small mb-1">Designation</label>
                                        <input readonly id="position2" type="text" class="form-control bg-light">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small mb-1">Region</label>
                                        <input readonly id="regdesc2" type="text" class="form-control bg-light">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small mb-1">KMUJ</label>
                                        <input readonly id="kmuj2" type="text" class="form-control bg-light">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small mb-1">Section</label>
                                        <input readonly id="section2" type="text" class="form-control bg-light">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-muted small mb-1">Current Level Entitle</label>
                                        <input readonly id="level2" type="text" class="form-control bg-light">
                                    </div>
                                </div>
                                <div class="col-lg-6 ps-lg-5 d-flex flex-column justify-content-between">
                                    <div>
                                        <h5 class="mb-4 text-success fw-semibold">Update Fields</h5>
                                        <div class="p-4 rounded-3 bg-success-transparent-2 border border-success border-opacity-10">
                                            <div class="mb-4">
                                                <label class="form-label fw-medium mb-1">New Level Entitle</label>
                                                <select id="userlevelnew" class="form-control form-select select2" required="required">
                                                    <option value="-0">.: Select User Level :.</option>
                                                </select>
                                            </div>
                                            <div id="regionnewdw">
                                                <div class="mb-4">
                                                    <label class="form-label fw-medium mb-1">Region</label>
                                                    <select id="regionnew" class="form-control form-select select2" required="required">
                                                        <option value="-0">.: Select Region :.</option>
                                                        <option value="North">North</option>
                                                        <option value="South">South</option>
                                                        <option value="East">East</option>
                                                        <option value="Central">Central</option>
                                                        <option value="HQ">HQ</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div id="kmujnewdw">
                                                <div class="mb-4">
                                                    <label class="form-label fw-medium mb-1">KMUJ</label>
                                                    <select id="kmujnew" class="form-control form-select select2" required="required" disabled>
                                                        <option value="-0">.: Select Kmuj :.</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div id="sectionnewdw">
                                                <div class="mb-4">
                                                    <label class="form-label fw-medium mb-1">Section</label>
                                                    <select id="sectionnew" class="form-control form-select select2" required="required" disabled>
                                                        <option value="-0">.: Select Section :.</option>

                                                    </select>
                                                </div>
                                            </div>
                                            <div class="mb-2">
                                                <label class="form-label fw-medium mb-1">Staff Status</label>
                                                <select id="statusnew" class="form-control form-select select2" required="required">
                                                    <option value="-0">.: Select Status :.</option>
                                                    <option value="active">Active</option>
                                                    <option value="inactive">Inactive</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2 justify-content-end mt-5 pt-3">
                                        <button class="btn btn-light px-4" data-bs-dismiss="modal" aria-label="Close" type="button">Cancel</button>
                                        <button id="submitUpdate" class="btn btn-success px-4" type="button">Update Data</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts{

    <script src="~/assets/scripts/dashboard.js"></script>
    <script src="~/assets/plugins/morris/morris.min.js"></script>
    <script src="~/assets/plugins/raphael/raphael.min.js"></script>
    <script src="~/assets/plugins/select2/select2.min.js"></script>

    <script type="text/javascript">
        checkSess();

        $(document).ready(function () {
            listKMUJ();
            listSection();
            maklumatStf();
            listUserLevel();
            listReports();

            // ---------  CHECK ACCESS ------------ //
            if (localStorage.getItem("lvlI") === "1" || localStorage.getItem("lvlI") === "5") {
                $("#contentAdmin").show();
                $("#contentOthers").hide();

                if (localStorage.getItem("lvlI") === "5") {
                    $('.btn-success[data-bs-target="#modalTambah"]').hide();
                } else {
                    $('.btn-success[data-bs-target="#modalTambah"]').show();
                }
            }
            else {
                $("#contentAdmin").hide();
                $("#contentOthers").show();
            }
  

            // ----------- ADD MODAL ---------------- //
            $('#region').on('change', function () {
                listKMUJ($(this).val(), '#kmuj');
            });

            $('#kmuj').on('change', function () {
                var kmujName = $(this).find("option:selected").text();
                var val = $(this).val();

                if (val && val !== "-0") {
                    listSection(kmujName, '#section'); 
                } else {
                    $('#section').html('<option value="-0">.: Select Section :.</option>').prop('disabled', true).trigger('change.select2');
                }
            });


            //buka modal tambah user
            $('#modalTambah').on('shown.bs.modal', function () {
                 if (localStorage.getItem("lvlI") === "5") {
                    $("#contentAdmin").show();
                    $("#contentOthers").hide();
                }
                $('#staffID').select2({
                    dropdownParent: $('#modalTambah'),
                    placeholder: "Type to search for Staff ID",
                    minimumInputLength: 1,
                    ajax: {
                        url: function (params) {
                            return linkDepan + "GetEngDetails?StaffId=" + params.term;
                        },
                        dataType: 'json',
                        delay: 250,
                        beforeSend: function (request) {
                            request.setRequestHeader("Token", localStorage.getItem('main'));
                        },
                        data: function (params) {
                            return {
                                StaffId: params.term
                            };
                        },
                        processResults: function (data) {
                            return {
                                results: $.map(data, function (item) {
                                    return {
                                        id: item.Emplid,
                                        text: item.Emplid
                                    };
                                })
                            };
                        },
                        cache: true
                    }
                }).on("select2:select", function (e) {
                    var selectedStaffID = e.params.data.id;
                    localStorage.setItem("selID", selectedStaffID);
                    console.log(selectedStaffID);
                    maklumatStf(selectedStaffID);
                })
                if ($('#modalTambah').on('hidden.bs.modal')) {
                    $('#staffID').val(null).trigger('change');
                    $('#staffname').val(null).trigger('change');
                    $('#position').val(null).trigger('change');
                    $('#region').val(null).trigger('change');
                    $("#kmuj").val("-0").trigger("change.select2");
                    $("#section").val("-0").trigger("change.select2");
                    $("#userlevel").val("-0").trigger("change.select2");
                }

            });

            //button submit add user
            $('#submitNew').click(function () {
                tambahUser();

            });








            // ------------- UPDATE MODAL ----------- //
            $('#regionnew').on('change', function () {
                var selectedText = $(this).find(':selected').text();
                var selectedValue = $(this).val();

                console.log("Value:", selectedValue, "Text:", selectedText);

                if (selectedText !== 'HQ') {
                    $('#kmujnew').prop('disabled', false);
                    listKMUJ(selectedValue, '#kmujnew');
                } else {
                    $('#kmujnew').prop('disabled', true);
                }
            });

            $('#kmujnew').on('change', function () {
                var kmujName = $(this).find("option:selected").text();
                var val = $(this).val();

                $('#sectionnew').val("-0").trigger('change.select2');

                if (val && val !== "-0") {
                    $('#sectionnew').prop('disabled', false);
                    listSection(kmujName, '#sectionnew');
                }
            });


            //modal details user
            $('#modalDetails').on('show.bs.modal', function (e) {
                $('#userlevelnew').val("-0").trigger('change.select2');
                $('#regionnew').val("-0").trigger('change.select2');

                $('#kmujnew').val("-0").trigger('change.select2');
                $('#sectionnew').val("-0").trigger('change.select2');
                $('#statusnew').val("-0").trigger('change.select2');

                $('#kmujnewdw, #sectionnewdw').hide();

                var ids = $(e.relatedTarget).data('id');
                $(this).data('id', ids);

                console.log('Opening modal for ID:', ids);

                if (ids) {
                    stfDet(ids);
                }
            });


            //button submit update user
            $("#submitUpdate").click(function () {
                var ids = $('#modalDetails').data('id');
                console.log('read ' + ids);
                updateUser(ids);
            });


            $('#userlevelnew').on('change', function () {
                updateVisibility();
            });


          


        });




        //---------------- ADD NEW USER -------------------- //


        //show maklumat staff on add user modal
        function maklumatStf(staffID) {
            console.log("maklumatStf called with staffID:", staffID);
            $.ajax({
                url: linkDepan + "GetUserDetails?StaffId=" + staffID,
                dataType: "json",
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (data) {
                    if (data && Array.isArray(data) && data.length > 0) {
                        let staff = data[0];

                        // Populate fields
                        $('#staffname').val(staff.Nama);
                        $('#region').val(staff.RegDesc);
                        $('#position').val(staff.JobDesc);

                        // Run visibility logic
                        updateFieldVisibility();
                    }
                },
                error: function (xhr) {
                    console.error("maklumatStf error callback:", xhr);
                    swarning();
                }
            });
        }

        $('#userlevel').on('change', function () {
            updateFieldVisibility();
        });

        function updateFieldVisibility() {
            var staffRegion = $('#region').val();
            var selectedLevel = $('#userlevel').val();

            // Condition: HQ OR (Level 2 or 6)
            if (staffRegion === 'HQ' || selectedLevel === '2' || selectedLevel === '6') {
                $('#kmujdw').hide('fast');
                $('#sectiondw').hide('fast');
            } else {
                $('#kmujdw').show('fast');
                $('#sectiondw').show('fast');

                // Only fetch list if visible and region is valid
                if (staffRegion && staffRegion !== 'HQ') {
                    listKMUJ(staffRegion, '#kmuj');
                }
            }
        }


        //submit new user button
        function tambahUser() {
            var data = {
                Userid: $('#staffID').val(),
                Nama: $('#staffname').val(),
                Designation: $('#position').val(),
                Region: $("#region").val(),
                KMUJ: $("#kmuj option:selected").val(),
                Section: $("#section option:selected").val(),
                UserLevel: $("#userlevel option:selected").val(),
            };

            var shouldBeEmpty = (data.Region === 'HQ' || data.UserLevel === '2' || data.UserLevel === '6');

            if (shouldBeEmpty) {
                if (data.KMUJ === '-0') data.KMUJ = ' ';
                if (data.Section === '-0') data.Section = ' ';

                if (data.UserLevel === '-0') {
                    swal.fire('Error!', 'Please ensure User Level is selected!', 'error');
                    return;
                }
            }
            else {
                if (data.KMUJ === '-0') {
                    swal.fire('Error!', 'Please ensure KMUJ is selected!', 'error');
                    return;
                }
                if (data.Section === '-0') {
                    swal.fire('Error!', 'Please ensure Section is selected!', 'error');
                    return;
                }
                if (data.UserLevel === '-0') {
                    swal.fire('Error!', 'Please ensure User Level is selected!', 'error');
                    return;
                }
            }

            executeUser(data);
        }


        //fx add new user 
        function executeUser(data) {
            console.log("UPDATING USER:", data.Userid);
            console.log("Nama:", data.Nama);
            console.log("Designation:", data.Designation);
            console.log("Region:", data.Region);
            console.log("KMUJ:", data.KMUJ);
            console.log("SECTION:", data.Section);
            console.log("USER LEVEL:", data.UserLevel);

            $.ajax({
                url: linkDepan + "NewUser",
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (response) {
                    var data;
                    try {
                        data = JSON.parse(response);
                    } catch (error) {
                        console.error("Error parsing JSON:", error);
                        swarning();
                        return;
                    }
                    if (data && data.status === "00") {
                        $('#modalTambah').modal('hide');
                        swal.fire('Success!', 'New user successfully added.', 'success');
                        listReports();
                    } else {
                        $('#modalTambah').modal('hide');
                        swarning();
                    }
                    console.log("Response data:", data);
                },
            });
        }



    // ------------------ UPDATE USER ------------------ //


        //show data on update details user modal
        function stfDet(ids) {
            $.ajax({
                url: linkDepan + "Get?StaffId=" + ids,
                type: 'GET',
                dataType: 'json',
                beforeSend: (request) => request.setRequestHeader("Token", localStorage.getItem('main')),
                success: function (data) {
                    if (data && data.length > 0) {
                        var staff = data[0];

                        // Populate fields
                        $('#staffID2').val(staff.staff_id);
                        $('#staffname2').val(staff.staff_name);
                        $('#dept2').val(staff.dept);
                        $('#position2').val(staff.position);
                        $('#level2').val(staff.ref_level_name);
                        $('#regdesc2').val(staff.section);
                        $('#kmuj2').val(staff.kmuj_name);
                        $('#section2').val(staff.section_name);

                        // Set values and trigger change
                        $('#userlevelnew').val().trigger('change.select2');
                        $('#statusnew').val().trigger('change.select2');

                        // Run the visibility logic
                        updateVisibility();
                    }
                }
            });
        }

        // Function to handle field visibility
        function updateVisibility() {
            var userLevel = $('#userlevelnew').val();
            var sectionVal = $('#regionnew').val();

            // Log the captured values to the console
            console.log("--- Visibility Update Check ---");
            console.log("Selected User Level:", userLevel);
            console.log("Selected Region:", sectionVal);

            // 1. Define conditions for hiding
            var isRestrictedLevel = (userLevel === "2" || userLevel === "6");
            var isHQ = (sectionVal === 'HQ');

            if (isRestrictedLevel || isHQ) {
                console.log("Logic: Hiding kmujnewdw and sectionnewdw");

                $('#regionnewdw').show('fast');
                $('#kmujnewdw, #sectionnewdw').hide('fast');

                $('#kmujnew').val("-0").trigger('change');
                $('#sectionnew').val("-0").trigger('change');
            } else {
                console.log("Logic: Showing all fields");
                $('#regionnewdw, #kmujnewdw, #sectionnewdw').show('fast');
            }
        }


        //update hal user
        function updateUser(ids) {
            var userLevel = $('#userlevelnew').val();
            var status = $('#statusnew').val();
            var region = $('#regionnew').val();
            var kmuj = $('#kmujnew').val();
            var section = $('#sectionnew').val();

            // Define business rules
            var isHQ = (region === "HQ");
            var isSpecialLevel = (userLevel === "2" || userLevel === "6");

            // Clear values if they meet the criteria for being empty
            if (isHQ || isSpecialLevel) {
                kmuj = "";
                section = "";
            }

            // Define what is actually considered a "missing" field
            // We only check for invalidity if it's NOT HQ and NOT a special level
            var isInvalid = function (val) {
                return ["", null, undefined, "0", "-0"].includes(val);
            };

            var hasInvalidField = isInvalid(userLevel) ||
                isInvalid(region) ||
                (!isHQ && !isSpecialLevel && (isInvalid(kmuj) || isInvalid(section)));

            if (hasInvalidField) {
                swal.fire({
                    icon: 'error',
                    title: 'Invalid Selection',
                    text: 'Please ensure all required fields are selected!',
                    target: document.getElementById('modalDetails')
                });
                return;
            }


            var data = {
                StaffId: ids,
                UserLevel: userLevel,
                Status: status,
                Region: region,
                Kmuj: kmuj, 
                Section: section,
                UpdBy: localStorage.getItem('usrI')
            };

            $.ajax({
                url: linkDepan + "UpdateUser",
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (response) {
                    var data;
                    try {
                        data = JSON.parse(response);
                    } catch (error) {
                        swarning();
                        return;
                    }
                    if (data && data.status === "00") {
                        $('#modalDetails').modal('hide');
                        swal.fire('Success!', 'User details have been updated.', 'success');
                        listReports();
                    } else {
                        $('#modalDetails').modal('hide');
                        swarning();
                    }
                },
            });
        }




       


      









     

        function listUserLevel() {
            $.ajax({
                url: linkDepan + "GetUserLevelList",
                dataType: "json",
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (data) {
                    $('#userlevel, #userlevelnew').html('<option value="-0">.: Select User Level :.</option>');

                    if (data.length >= 1) {
                        auxArr = [];
                        $.each(data, function (index, value) {
                            auxArr[index] = "<option value='" + value.ref_level_no + "'>" + value.ref_level_name + "</option>";
                        });
                        $('#userlevel, #userlevelnew').append(auxArr.join(''));
                    } else {
                        $("#userlevel, #userlevelnew").addClass(" is-invalid");

                    }
                },
                error: function (xhr) {
                    swarning();
                },
                complete: function () {
                }
            });
        }

