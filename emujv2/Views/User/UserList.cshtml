        function listKMUJ(region, targetID) {
            $.ajax({
                url: linkDepan + "Reg?Region=" + region,
                dataType: "json",
                beforeSend: function (request) {
                    request.setRequestHeader("Token", localStorage.getItem('main'));
                },
                success: function (data) {
                    var $target = $(targetID); // Use the specific target provided
                    var auxArr = ["<option value='-0'>.: Select KMUJ :.</option>"];

                    if (data && data.length >= 1) {
                        $.each(data, function (index, value) {
                            auxArr.push("<option value='" + value.kmuj_value + "'>" + value.kmuj_name + "</option>");
                        });
                        $target.html(auxArr.join('')).prop('disabled', false);
                    } else {
                        $target.html('<option value="-0">.: Select KMUJ :.</option>').prop('disabled', true);
                    }

                    // REFRESH SELECT2
                    if ($target.hasClass("select2-hidden-accessible")) {
